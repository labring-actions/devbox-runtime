#!/command/with-contenv bash
# shellcheck disable=SC1008
set -euo pipefail

DEFAULT_DEVBOX_USER=${DEFAULT_DEVBOX_USER:-devbox}
CODEX_GATEWAY_ROOT=${CODEX_GATEWAY_ROOT:-/opt/codex-gateway}

DEVBOX_HOME="$(getent passwd "$DEFAULT_DEVBOX_USER" | cut -d: -f6 || true)"
if [ -z "$DEVBOX_HOME" ]; then
    DEVBOX_HOME="/home/${DEFAULT_DEVBOX_USER}"
fi

GATEWAY_HOST=${CODEX_GATEWAY_HOST:-0.0.0.0}
GATEWAY_PORT=${CODEX_GATEWAY_PORT:-1317}
GATEWAY_CODEX_HOME=${CODEX_GATEWAY_CODEX_HOME:-/codex-home}
GATEWAY_CWD=${CODEX_GATEWAY_CWD:-${DEVBOX_HOME}/workspace}
GATEWAY_CODEX_BIN=${CODEX_GATEWAY_CODEX_BIN:-codex}
GATEWAY_DEFAULT_MODEL=${CODEX_GATEWAY_MODEL:-}
GATEWAY_DEBUG=${CODEX_GATEWAY_DEBUG:-}
GATEWAY_MAX_SESSIONS=${CODEX_GATEWAY_MAX_SESSIONS:-12}
GATEWAY_SESSION_TTL_MS=${CODEX_GATEWAY_SESSION_TTL_MS:-1800000}
GATEWAY_SESSION_SWEEP_INTERVAL_MS=${CODEX_GATEWAY_SESSION_SWEEP_INTERVAL_MS:-60000}
GATEWAY_OPENAI_API_KEY=${CODEX_GATEWAY_OPENAI_API_KEY:-}
GATEWAY_OPENAI_BASE_URL=${CODEX_GATEWAY_OPENAI_BASE_URL:-}

export HOME="$DEVBOX_HOME"
export USER="$DEFAULT_DEVBOX_USER"
export LOGNAME="$DEFAULT_DEVBOX_USER"
export CODEX_GATEWAY_HOST="$GATEWAY_HOST"
export CODEX_GATEWAY_PORT="$GATEWAY_PORT"
export CODEX_GATEWAY_CODEX_HOME="$GATEWAY_CODEX_HOME"
export CODEX_GATEWAY_CWD="$GATEWAY_CWD"
export CODEX_GATEWAY_CODEX_BIN="$GATEWAY_CODEX_BIN"
export CODEX_GATEWAY_MAX_SESSIONS="$GATEWAY_MAX_SESSIONS"
export CODEX_GATEWAY_SESSION_TTL_MS="$GATEWAY_SESSION_TTL_MS"
export CODEX_GATEWAY_SESSION_SWEEP_INTERVAL_MS="$GATEWAY_SESSION_SWEEP_INTERVAL_MS"

# Mirror gateway-owned values to the child env names that Codex itself reads.
export CODEX_HOME="$GATEWAY_CODEX_HOME"
export CODEX_BIN="$GATEWAY_CODEX_BIN"

if [ -n "$GATEWAY_DEFAULT_MODEL" ]; then
    export CODEX_GATEWAY_MODEL="$GATEWAY_DEFAULT_MODEL"
    export CODEX_MODEL="$GATEWAY_DEFAULT_MODEL"
fi

if [ -n "$GATEWAY_DEBUG" ]; then
    export CODEX_GATEWAY_DEBUG="$GATEWAY_DEBUG"
    export DEBUG="$GATEWAY_DEBUG"
fi

if [ -n "$GATEWAY_OPENAI_API_KEY" ]; then
    export CODEX_GATEWAY_OPENAI_API_KEY="$GATEWAY_OPENAI_API_KEY"
    export OPENAI_API_KEY="$GATEWAY_OPENAI_API_KEY"
fi

if [ -n "$GATEWAY_OPENAI_BASE_URL" ]; then
    export CODEX_GATEWAY_OPENAI_BASE_URL="$GATEWAY_OPENAI_BASE_URL"
    export CODEX_OPENAI_BASE_URL="$GATEWAY_OPENAI_BASE_URL"
    export OPENAI_BASE_URL="$GATEWAY_OPENAI_BASE_URL"
fi

mkdir -p "$GATEWAY_CODEX_HOME" "$GATEWAY_CWD"
chown "$DEFAULT_DEVBOX_USER:$DEFAULT_DEVBOX_USER" "$GATEWAY_CODEX_HOME" "$GATEWAY_CWD" || true

if [ ! -x /usr/local/bin/codex-gateway ]; then
    echo "codex-gateway binary not found at /usr/local/bin/codex-gateway" >&2
    exit 111
fi

if [ ! -d "${CODEX_GATEWAY_ROOT}/public" ]; then
    echo "codex-gateway public assets not found at ${CODEX_GATEWAY_ROOT}/public" >&2
    exit 111
fi

cd "$CODEX_GATEWAY_ROOT"
exec 2>&1
exec s6-setuidgid "$DEFAULT_DEVBOX_USER" /usr/local/bin/codex-gateway
